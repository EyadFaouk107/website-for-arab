{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/about",          "destination": "/about.html" },
    { "source": "/projects",       "destination": "/projects.html" },
    { "source": "/project-detail", "destination": "/project-detail.html" },
    { "source": "/sectors",        "destination": "/sectors.html" },
    { "source": "/innovation",     "destination": "/innovation.html" },
    { "source": "/careers",        "destination": "/careers.html" },
    { "source": "/contact",        "destination": "/contact.html" },
    { "source": "/news",           "destination": "/news.html" }
  ]
}
